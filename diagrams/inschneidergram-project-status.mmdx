flowchart TD
  api["DONE GREEN API contract"]
  store["PLANNED YELLOW Persistent store"]
  adapter["PLANNED RED Delivery adapter"]
  sender["PLANNED RED Sender operations"]
  webhooks["PLANNED YELLOW Outgoing webhooks"]
  pilot["FUTURE RED Graphed pilot"]
  api --> store
