{
  "name": "inschneidergram",
  "version": "0.1.0",
  "description": "API-first Instagram creator outreach control plane for managed campaign pilots.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "demo:manual-pilot": "tsx scripts/manual-pilot-rehearsal.ts",
    "demo:pilot": "tsx scripts/pilot-demo.ts",
    "pilot:provider-bridge": "tsx scripts/managed-provider-bridge-rehearsal.ts",
    "pilot:intake:rehearse": "tsx scripts/pilot-intake-api-rehearsal.ts",
    "pilot:intake:validate": "tsx scripts/validate-pilot-intake.ts",
    "proof:bounty-local": "bash scripts/bounty-local-proof.sh",
    "presmoke:service": "npm run build",
    "smoke:docker": "bash scripts/docker-smoke.sh",
    "smoke:service": "tsx scripts/service-smoke.ts",
    "status:mmdx:dry-run": "bash scripts/publish-status-mmdx.sh dry-run",
    "status:mmdx:list": "bash scripts/publish-status-mmdx.sh list",
    "status:mmdx:login": "bash scripts/publish-status-mmdx.sh login",
    "status:mmdx:preflight": "bash scripts/publish-status-mmdx.sh preflight",
    "status:mmdx:publish": "bash scripts/publish-status-mmdx.sh publish",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "fastify": "^5.6.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=22"
  }
}
